# Node Environment (development/production)
NODE_ENV=development

# Server Port
PORT=5000

# JWT Cryptographic Signing Keys (Must be at least 32 characters in production)
JWT_SECRET=your_super_secret_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=15m

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rescuelink
DB_USER=postgres
DB_PASSWORD=your_password

# Redis Cache and Socket Coordinator
REDIS_URL=redis://localhost:6379

# Twilio API Integration (SMS and WhatsApp alerts)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Firebase Admin SDK Configuration (Push Notifications)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# Google Maps Platform API Key (Directions + Traffic layers)
GOOGLE_MAPS_API_KEY=your_google_maps_key

# Razorpay Gateway Credentials
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ABDM National Gateway Credentials
ABDM_CLIENT_ID=your_abdm_client_id
ABDM_CLIENT_SECRET=your_abdm_client_secret
ABDM_BASE_URL=https://dev.abdm.gov.in

# Daily.co WebRTC Video Telemedicine Key
DAILY_CO_API_KEY=your_daily_co_key

# Application-layer PII/PHI Encryption Key (Must be 32-byte hex/string key)
ENCRYPTION_KEY=2b7e151628aed2a6abf7158809cf4f3c2b7e151628aed2a6abf7158809cf4f3c

# Production CORS Allowlists (Required in production)
PRODUCTION_URL=https://staging.rescuelink.in
FRONTEND_URL=https://staging.rescuelink.in
